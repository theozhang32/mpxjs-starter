{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "noImplicitThis": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": [],
    "paths": {
      "@/*": ["./src/*"],
      "@vant/weapp/*": ["./node_modules/@vant/weapp/dist/*"]
    }
  },
  "exclude": ["build", "dist", "config"]
}
